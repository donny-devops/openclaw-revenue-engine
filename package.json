{
  "name": "openclaw-revenue-engine",
  "version": "1.0.0",
  "description": "Self-hosted revenue engine for OpenClaw agents — usage metering, Stripe billing, client invoicing, and earnings dashboards",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "express": "^4.19.2",
    "stripe": "^16.0.0",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "zod": "^3.23.8",
    "winston": "^3.13.0",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/donny-devops/openclaw-revenue-engine.git"
  },
  "keywords": [
    "revenue-engine",
    "stripe",
    "billing",
    "devops",
    "typescript",
    "nodejs",
    "api"
  ]
}
