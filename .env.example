# =============================================================================
# openclaw-revenue-engine — Environment Variables
# Copy to .env and fill in your values. Never commit .env to source control.
# =============================================================================

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/revenue_engine
DB_HOST=localhost
DB_PORT=5432
DB_NAME=revenue_engine
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_POOL_MIN=2
DB_POOL_MAX=10

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2024-06-20

# Authentication
JWT_SECRET=change_me_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# GitHub Webhooks
GITHUB_WEBHOOK_SECRET=change_me_to_a_random_secret

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional — for session/cache)
REDIS_URL=redis://localhost:6379

# Monitoring / Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_EMAIL=alerts@yourdomain.com

# =============================================================================
# Quick Question | Agent Contact lane — AI README Generator (MaxClaw)
# =============================================================================
# MaxClaw (Anthropic Claude) writes the README. Required.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Model override for the README generator. Defaults to claude-sonnet-4-20250514.
README_GENERATOR_MODEL=claude-sonnet-4-20250514

# Needed for repo analysis (5000 req/hr instead of 60) AND Gist publishing.
# Scopes required: `gist` + `public_repo`.
GITHUB_TOKEN=ghp_your_token_with_gist_and_public_repo_scopes

# Moltgate REST API — polled every 5 min by .github/workflows/poll.yml.
MOLTGATE_API_KEY=mg_key_your_moltgate_api_key_here
MOLTGATE_BASE_URL=https://moltgate.com
MOLTGATE_PROFILE_HANDLE=your-moltgate-handle

# Where the lane handler appends its delivery audit log. Defaults to
# ./deliveries.jsonl. Keep this file gitignored.
DELIVERIES_LOG_PATH=deliveries.jsonl
